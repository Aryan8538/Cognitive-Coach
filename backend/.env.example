# CognitiveCoach Environment Variables Example
# Duplicate this file as '.env' and provide your keys

# --- AI (optional) ---
# When omitted, the platform runs in offline "sandbox" mode.
GEMINI_API_KEY=your_gemini_api_key_here

# --- Auth (optional, but required for real per-user data isolation) ---
# Secret used to sign/verify tokens issued by this backend's /api/auth endpoints.
# Set a strong random value in production; the built-in default is NOT safe.
JWT_SECRET=31d7cda93b8cceba88f96d161e0fd27cadeb253d0db8772b3ba5858b86979fba

# Supabase project JWT secret (Supabase Dashboard -> Project Settings -> API -> JWT Secret).
# Required to verify Supabase logins on the backend and enforce per-user isolation.
# If unset, Supabase sessions are treated as anonymous sandbox users (no isolation),
# and the app keeps working exactly as it does today in guest mode.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
